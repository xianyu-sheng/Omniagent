name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  test:
    runs-on: windows-latest
    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: "true"
      PYTHONUTF8: "1"
      PYTHONIOENCODING: utf-8
      PYTEST_DISABLE_PLUGIN_AUTOLOAD: "1"

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install
        run: python -m pip install -e ".[dev]"

      - name: Show Python environment
        run: |
          python --version
          python -c "import locale, sys; print(sys.getfilesystemencoding()); print(locale.getpreferredencoding(False))"

      - name: Compile package
        run: python -m compileall omniagent evals

      - name: Run tests
        run: python -m pytest tests -q --tb=short

      - name: Run mock eval
        run: python evals/runner.py --mode mock --output evals/reports/mock_report.md
